{
  "name": "newsmap",
  "version": "0.1.0",
  "private": true,
  "description": "NewsMap — fullstack news geo-visualization platform",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/ui",
    "shared/types"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.dev.yml down"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
